<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Otsikko -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Mikä virhe koodissa on?"
        android:textSize="30sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Koodialue -->
    <TextView
        android:id="@+id/codeText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="int x = &quot;hello&quot;;"
        android:textSize="16sp"
        android:typeface="monospace"
        android:background="#EEEEEE"
        android:padding="50dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Vastausnapit -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSyntax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:paddingVertical="16dp"
            android:textSize="18sp"
            android:backgroundTint="@color/blue"
            android:text="Syntaksivirhe"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnComparison"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:paddingVertical="16dp"
            android:textSize="18sp"
            android:backgroundTint="@color/blue"
            android:text="Vertailu- ja sijoitusvirhe"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:paddingVertical="16dp"
            android:textSize="18sp"
            android:backgroundTint="@color/blue"
            android:text="Tietotyyppivirhe"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnLogic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:paddingVertical="16dp"
            android:textSize="18sp"
            android:backgroundTint="@color/blue"
            android:text="Logiikkavirhe"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:paddingVertical="16dp"
            android:textSize="18sp"
            android:backgroundTint="@color/black"
            android:textColor="@color/white"
            android:text="Tarkastele tuloksia"
            android:layout_marginBottom="8dp"
            android:enabled="false"/>

        <Button
            android:id="@+id/btnRestart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:paddingVertical="16dp"
            android:textSize="18sp"
            android:backgroundTint="@color/pink"
            android:textColor="@color/black"
            android:text="Aloita alusta"
            android:enabled="false"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>